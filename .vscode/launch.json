{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Pytest: Debug backtester tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q", "apps/backtester/tests"],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
