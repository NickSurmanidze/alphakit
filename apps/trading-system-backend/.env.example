NODE_ENV=development
PORT=4000

MONGO_URI=mongodb://mongo:mongo@localhost:27018/mongo?authSource=mongo

ACCESS_TOKEN_SECRET=change-me-access-secret
REFRESH_TOKEN_SECRET=change-me-refresh-secret

# Only used when NODE_ENV !== production, to allow the Vite dev server to call this API cross-origin
UI_DEV_ORIGIN=http://localhost:5173

# Set on cookies in production (e.g. .yourdomain.com); leave unset for localhost
COOKIE_DOMAIN=

REDIS_HOST=localhost
REDIS_PORT=63794
REDIS_PASSWORD=

TIMESCALE_URL=postgres://timescale:timescale@localhost:5432/timescale

# IB Gateway socket connection (see infra/docker-compose.yml's ib-gateway service). Read by this
# app's own code (env.ts). Port 4004, NOT 4002 -- 4002 is only reachable inside the gateway
# container itself; 4004 is the image's own socat relay, which is what's actually published to
# the host.
IB_GATEWAY_HOST=localhost
IB_GATEWAY_PORT=4004
IB_CLIENT_ID=11

# TWS_USERID/TWS_PASSWORD/TRADING_MODE below are NOT read by this app's code -- they're your
# actual TWS/IB Gateway login, passed straight through to the ib-gateway docker container via its
# `env_file:` in infra/docker-compose.yml, so the names have to match what that image expects
# exactly (not app code's IB_* naming). Not a simple API key. Keep this file untracked (already
# covered by .gitignore) and never commit real values.
TWS_USERID=
TWS_PASSWORD=
TRADING_MODE=paper

# Databento Historical API key (https://databento.com/portal/keys). Read by this app's own code
# (env.ts). Optional -- only needed once a databento-sourced instrument is registered.
DATABENTO_API_KEY=
